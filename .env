# 파이프라인 튜너블 — 코드 수정 없이 여기만 바꿔서 재실행.
# (llm/config.py 가 읽는다. 프롬프트는 llm/prompts/*.md 에 있음.)

# 분석에 쓸 ollama 로컬 모델.
#   현재:      gemma4:26b
#   베이크오프 후보 (32GB VRAM / 라이선스 clean):
#     gemma3:27b            (Gemma license,  ~17GB Q4)
#     mistral-small3.2:24b  (Apache 2.0,     ~15GB Q4)
#     phi4:14b              (MIT,            ~9GB  Q4)
MODEL=gemma4:26b

# 컨텍스트 크기 (tier1 주입 + 보고서까지 여유). 프롬프트 축소 + 크게 잡아 evidence 안 잘리게.
#   VRAM 부족하면 낮추고, 넉넉하면 131072 까지 올려도 됨.
NUM_CTX=65536

# 샘플링 (재현성 위해 낮은 temp + 고정 seed)
TEMPERATURE=0.3
SEED=42
